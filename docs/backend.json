
{
  "entities": {
    "Turf": {
      "title": "Turf",
      "description": "A sports venue listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "sports": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "whatsapp": { "type": "string" },
        "isActive": { "type": "boolean" },
        "price": { "type": "string" },
        "rating": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Athlete identity data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "area": { "type": "string" },
        "skillLevel": { "type": "string" },
        "favoriteSports": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["online", "away", "offline", "in_match"] },
        "rewardPoints": { "type": "number" },
        "lastActive": { "type": "object" }
      }
    },
    "Post": {
      "title": "Post",
      "description": "A social feed update or match request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "game": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "playersNeeded": { "type": "number" },
        "likes": { "type": "number" },
        "postedBy": {
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "photoURL": { "type": "string" }
          }
        },
        "createdAt": { "type": "object" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A private chat session between two athletes",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object" },
        "participantPhotos": { "type": "object" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "object" },
        "unreadCount": { "type": "object" },
        "relatedPostId": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "A single communication node within a conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/turfs/{turfId}": {
      "schema": "Turf",
      "description": "Venue listings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Athlete profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social wall posts"
    },
    "/conversations/{convoId}": {
      "schema": "Conversation",
      "description": "Direct message threads"
    },
    "/conversations/{convoId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Thread communications"
    }
  }
}
