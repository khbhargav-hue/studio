
{
  "entities": {
    "Turf": {
      "title": "Turf",
      "description": "A sports venue listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "sports": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "whatsapp": { "type": "string" },
        "isActive": { "type": "boolean" },
        "price": { "type": "string" },
        "rating": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Athlete identity data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "area": { "type": "string" },
        "skillLevel": { "type": "string" },
        "favoriteSports": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["online", "away", "offline", "in_match"] },
        "rewardPoints": { "type": "number" },
        "lastActive": { "type": "object" }
      }
    },
    "Post": {
      "title": "Post",
      "description": "A social feed update or match request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "game": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "playersNeeded": { "type": "number" },
        "likes": { "type": "number" },
        "postedBy": {
          "type": "object",
          "properties": {
            "uid": { "type": "string" },
            "name": { "type": "string" },
            "photoURL": { "type": "string" }
          }
        },
        "createdAt": { "type": "object" }
      }
    },
    "Ad": {
      "title": "Ad",
      "description": "Sponsored content node",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "placement": { "type": "string" },
        "isActive": { "type": "boolean" },
        "clickCount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/turfs/{turfId}": {
      "schema": "Turf",
      "description": "Venue listings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Athlete profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Social wall posts"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Sponsored nodes"
    },
    "/settings/branding": {
      "schema": "object",
      "description": "Platform global config"
    }
  }
}
