
{
  "entities": {
    "Turf": {
      "title": "Turf",
      "description": "A comprehensive sports turf venue listing with detailed facilities and pricing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "whatsapp": { "type": "string" },
        "imageUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "address": { "type": "string" },
        "area": { "type": "string" },
        "city": { "type": "string" },
        "pincode": { "type": "string" },
        "googleMapsUrl": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "sports": { "type": "array", "items": { "type": "string" } },
        "pitchType": { "type": "string" },
        "pitchSizes": { "type": "array", "items": { "type": "string" } },
        "dimensions": { "type": "string" },
        "maxPlayers": { "type": "number" },
        "pricePerHour": { "type": "number" },
        "peakHourPrice": { "type": "number" },
        "peakHoursStart": { "type": "string" },
        "slotDuration": { "type": "number" },
        "openTime": { "type": "string" },
        "closeTime": { "type": "string" },
        "openDays": { "type": "array", "items": { "type": "string" } },
        "checkInMinutes": { "type": "number" },
        "amenities": {
          "type": "object",
          "properties": {
            "parking": { "type": "boolean" },
            "changingRooms": { "type": "boolean" },
            "showers": { "type": "boolean" },
            "drinkingWater": { "type": "boolean" },
            "floodlights": { "type": "boolean" },
            "firstAid": { "type": "boolean" },
            "cafeteria": { "type": "boolean" },
            "washrooms": { "type": "boolean" },
            "ballProvided": { "type": "boolean" },
            "metalStudsOk": { "type": "boolean" }
          }
        },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "rules": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" },
        "views": { "type": "number" },
        "whatsappClicks": { "type": "number" }
      },
      "required": ["name", "area", "pricePerHour"]
    },
    "Review": {
      "title": "Review",
      "description": "Player feedback and rating for a sports arena",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "object" }
      },
      "required": ["userId", "rating"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Extended athlete data including rewards and level",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "rewardPoints": { "type": "number" },
        "level": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "createdAt": { "type": "object" },
        "updatedAt": { "type": "object" }
      }
    },
    "Team": {
      "title": "Team",
      "description": "A permanent sports team created by an athlete",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "area": { "type": "string" },
        "captain": { "type": "string" },
        "whatsapp": { "type": "string" },
        "logoUrl": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "ownerId": { "type": "string" },
        "wins": { "type": "number" },
        "matchesPlayed": { "type": "number" },
        "description": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["name", "sport", "ownerId"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/turfs/{turfId}": {
      "schema": "Turf",
      "description": "Collection of premium sports arenas"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of athlete profiles and rewards"
    },
    "/turfs/{turfId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Sub-collection of player reviews for each arena"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Collection of permanent athlete squads"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Collection of match circuit claims"
    }
  }
}
