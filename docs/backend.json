
{
  "entities": {
    "Turf": {
      "title": "Turf",
      "description": "A sports turf venue listing with facilities and coaching services",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "area": { "type": "string" },
        "sportTypes": { "type": "array", "items": { "type": "string", "enum": ["Cricket", "Football", "Pickleball"] } },
        "courtTypes": { "type": "array", "items": { "type": "string" } },
        "pricePerHour": { "type": "number" },
        "courtPricing": { 
          "type": "object", 
          "additionalProperties": { "type": "number" }
        },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "mainImage": { "type": "string" },
        "galleryImages": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "amenities": { "type": "array", "items": { "type": "string" } },
        "openingHours": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "isPopular": { "type": "boolean" },
        "views": { "type": "number" },
        "whatsappClicks": { "type": "number" },
        "updatedAt": { "type": "object" }
      },
      "required": ["name", "area", "pricePerHour"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Information about a booking inquiry",
      "type": "object",
      "properties": {
        "turfId": { "type": "string" },
        "turfName": { "type": "string" },
        "area": { "type": "string" },
        "sportType": { "type": "string" },
        "timestamp": { "type": "object" },
        "deviceInfo": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" }
      }
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Global application usage statistics",
      "type": "object",
      "properties": {
        "totalViews": { "type": "number" },
        "totalWhatsAppClicks": { "type": "number" },
        "totalUsers": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/turfs/{turfId}": {
      "schema": "Turf",
      "description": "Collection of sports turfs"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Collection of booking leads"
    },
    "/analytics/stats": {
      "schema": "Analytics",
      "description": "Global usage statistics"
    }
  }
}
