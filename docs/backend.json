
{
  "entities": {
    "Turf": {
      "title": "Turf",
      "description": "A sports venue listing",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "area": { "type": "string" },
        "sports": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "whatsapp": { "type": "string" },
        "isActive": { "type": "boolean" },
        "price": { "type": "string" },
        "rating": { "type": "number" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Athlete identity data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "area": { "type": "string" },
        "skillLevel": { "type": "string" },
        "favoriteSports": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["online", "away", "offline", "in_match"] },
        "rewardPoints": { "type": "number" },
        "lastActive": { "type": "object" }
      }
    },
    "MatchRequest": {
      "title": "MatchRequest",
      "description": "A social post seeking players or opponents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "creatorPhoto": { "type": "string" },
        "sport": { "type": "string" },
        "slotsNeeded": { "type": "number" },
        "slotsFilled": { "type": "number" },
        "area": { "type": "string" },
        "location": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "filled", "cancelled"] },
        "likes": { "type": "number" },
        "joinedUsers": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" }
      }
    },
    "Ad": {
      "title": "Ad",
      "description": "Sponsored content node",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "targetUrl": { "type": "string" },
        "placement": { "type": "string" },
        "isActive": { "type": "boolean" },
        "clickCount": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "/turfs/{turfId}": {
      "schema": "Turf",
      "description": "Venue listings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Athlete profiles"
    },
    "/matchRequests/{matchId}": {
      "schema": "MatchRequest",
      "description": "Social feed posts"
    },
    "/ads/{adId}": {
      "schema": "Ad",
      "description": "Sponsored nodes"
    },
    "/settings/branding": {
      "schema": "object",
      "description": "Platform global config"
    }
  }
}
