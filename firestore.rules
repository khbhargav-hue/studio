
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /turfs/{turfId} {
      allow read: if true;
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'whatsappClicks', 'updatedAt', 'rating', 'reviewCount'])
      ) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /turfs/{turfId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /teams/{teamId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /coaches/{coachId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /pools/{poolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount']) || isAdmin();
      allow create, delete: if isAdmin();
    }

    match /analytics/{docId} {
      allow read: if true;
      allow create, update: if true;
    }

    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
