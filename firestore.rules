rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the designated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    // Rules for the 'turfs' collection
    match /turfs/{turfId} {
      // Anyone can see the venues
      allow read: if true;
      
      // Anyone can increment view counts or clicks (allow create if the doc exists or is being updated)
      // Note: We use setDoc with merge on the client, which maps to create/update
      allow create, update: if request.resource.data.diff(resource.data || {}).affectedKeys()
        .hasOnly(['views', 'whatsappClicks', 'updatedAt', 'id', 'name', 'area', 'location', 'pricePerHour', 'courtPricing', 'rating', 'reviewCount', 'images', 'description', 'amenities', 'coachingServices', 'openingHours', 'contactNumber', 'whatsappNumber', 'mapUrl', 'isPopular'])
        || isAdmin();
      
      // Admin has full control
      allow write, delete: if isAdmin();
    }

    // Rules for global analytics
    match /analytics/{docId} {
      // Public can see nothing, but only admin can read the full stats
      allow read: if isAdmin();
      
      // Anyone can update counters
      allow create, update: if request.resource.data.diff(resource.data || {}).affectedKeys()
        .hasOnly(['totalViews', 'totalWhatsAppClicks', 'totalUsers']);
      
      // Admin can manage analytics documents fully
      allow write, delete: if isAdmin();
    }

    // Rules for branding and settings
    match /settings/branding {
      // Branding must be public for the hero section to load
      allow read: if true;
      // Only admin can change branding
      allow write, update: if isAdmin();
    }

    // General fallback for settings subcollections
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}