rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the designated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    // Rules for the 'turfs' collection
    match /turfs/{turfId} {
      // Anyone can see the venues
      allow read: if true;
      
      // Public can update specific stats with strict validation
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'whatsappClicks', 'updatedAt']) &&
        // Prevent spam: only allow incrementing or keeping same
        (request.resource.data.views >= resource.data.views && request.resource.data.views <= resource.data.views + 1) &&
        (request.resource.data.whatsappClicks >= resource.data.whatsappClicks && request.resource.data.whatsappClicks <= resource.data.whatsappClicks + 1)
      ) || isAdmin();
      
      // Only admin can manage listings
      allow create, delete: if isAdmin();
      allow write: if isAdmin();
    }

    // Rules for global analytics
    match /analytics/{docId} {
      // Only admin can see full platform performance
      allow read: if isAdmin();
      
      // Anyone can update counters, but restricted to increment operations
      allow create, update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalViews', 'totalWhatsAppClicks'])
      ) || isAdmin();
    }

    // Rules for booking leads
    match /leads/{leadId} {
      // Only admin can see the lead intelligence
      allow read: if isAdmin();
      
      // Public can create leads with validation
      allow create: if (
        request.resource.data.keys().hasAll(['turfId', 'turfName', 'timestamp', 'deviceInfo']) &&
        request.resource.data.turfId is string &&
        request.resource.data.timestamp == request.time
      );
      
      // Only admin can update or delete leads
      allow update, delete: if isAdmin();
    }

    // Rules for administrative activity logs
    match /logs/{logId} {
      allow create: if true; // Allow logging login attempts
      allow read, update, delete: if isAdmin();
    }

    // Rules for branding and settings
    match /settings/branding {
      allow read: if true;
      allow write, update: if isAdmin();
    }

    // General fallback for other settings
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}