
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    match /turfs/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /turfs/{turfId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /pools/{id} { allow read: if true; allow write: if isAdmin(); }
    match /coaches/{id} { allow read: if true; allow write: if isAdmin(); }
    match /teams/{id} { allow read: if true; allow write: if request.auth != null; }
    match /challenges/{id} { allow read: if true; allow write: if request.auth != null; }
    match /ads/{id} { allow read: if true; allow write: if isAdmin(); }
    
    match /analytics/{docId} { allow read, write: if true; }
    match /leads/{leadId} { allow create: if true; allow read: if isAdmin(); }
    match /settings/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /logs/{logId} { allow create: if true; allow read: if isAdmin(); }
  }
}
