rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the designated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    // Rules for the 'turfs' collection
    match /turfs/{turfId} {
      // Anyone can see the venues
      allow read: if true;
      
      // Anyone can increment view counts or clicks
      // We allow updates to these specific fields for any user
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['views', 'whatsappClicks', 'updatedAt']) || isAdmin();
      
      // Allow creation of these fields if the doc is being initialized via public interaction
      allow create: if request.resource.data.keys().hasAny(['views', 'whatsappClicks']) || isAdmin();
      
      // Admin has full control for everything else
      allow delete: if isAdmin();
      allow write: if isAdmin();
    }

    // Rules for global analytics
    match /analytics/{docId} {
      // Public can see nothing, but only admin can read the full stats
      allow read: if isAdmin();
      
      // Anyone can update counters
      allow create, update: if true;
      
      // Admin can manage analytics documents fully
      allow write, delete: if isAdmin();
    }

    // Rules for branding and settings
    match /settings/branding {
      allow read: if true;
      allow write, update: if isAdmin();
    }

    // General fallback for other settings
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}