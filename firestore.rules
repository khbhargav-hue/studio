rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is the designated admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khbhargav@gmail.com";
    }

    // Rules for the 'turfs' collection
    match /turfs/{turfId} {
      // Anyone can see the venues
      allow read: if true;
      
      // Anyone can increment view counts or clicks
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['views', 'whatsappClicks', 'updatedAt']);
      
      // Admin has full control
      allow write, update, delete: if isAdmin();
    }

    // Rules for global analytics
    match /analytics/{docId} {
      // Public can update counters, but only admin can read the full stats
      allow read: if isAdmin();
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['totalViews', 'totalWhatsAppClicks', 'totalUsers']);
      
      // Admin can manage analytics documents
      allow create, delete: if isAdmin();
      allow update: if isAdmin();
    }

    // Rules for branding and settings
    match /settings/branding {
      // Branding must be public for the hero section to load
      allow read: if true;
      // Only admin can change branding
      allow write, update: if isAdmin();
    }

    // General fallback for settings subcollections
    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}