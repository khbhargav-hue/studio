rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Match Circuit Rules
    match /matches/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.postedBy.uid;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Administrative Rules (Turfs & Branding)
    match /turfs/{turfId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'khbhargav@gmail.com';
    }
    
    match /settings/branding {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'khbhargav@gmail.com';
    }

    match /ads/{adId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'khbhargav@gmail.com';
    }

    // Default Fallback
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'khbhargav@gmail.com';
    }
  }
}